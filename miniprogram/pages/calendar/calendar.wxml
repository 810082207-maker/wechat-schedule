<!--pages/calendar/calendar.wxml-->
<view class="container">
  <!-- 月份导航 -->
  <view class="month-nav">
    <view class="nav-btn" bindtap="prevMonth">
      <text class="nav-icon">‹</text>
    </view>
    <view class="month-title">
      <text>{{currentYear}}年{{currentMonth}}月</text>
    </view>
    <view class="nav-btn" bindtap="nextMonth">
      <text class="nav-icon">›</text>
    </view>
  </view>

  <!-- 星期头部 -->
  <view class="week-header">
    <view class="week-day" wx:for="{{['日', '一', '二', '三', '四', '五', '六']}}" wx:key="*this">
      {{item}}
    </view>
  </view>

  <!-- 日历网格 -->
  <view class="calendar-grid">
    <view class="week-row" wx:for="{{weeks}}" wx:key="index">
      <view
        class="day-cell {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{selectedDate === item.date ? 'selected' : ''}} {{schedules[item.date] ? 'has-schedule' : ''}}"
        wx:for="{{item}}"
        wx:for-item="day"
        wx:key="date"
        bindtap="selectDate"
        data-date="{{day.date}}"
      >
        <text class="day-number">{{day.day}}</text>
        <view class="schedule-dots" wx:if="{{schedules[day.date]}}">
          <view class="dot" wx:for="{{schedules[day.date]}}" wx:for-item="s" wx:key="_id" wx:if="{{index < 3}}"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 选中日期的日程列表 -->
  <view class="selected-schedules">
    <view class="section-header">
      <text class="section-title">{{selectedDate}} 日程</text>
      <text class="add-btn" bindtap="createSchedule">+ 添加</text>
    </view>

    <view class="schedule-list" wx:if="{{todaySchedules.length > 0}}">
      <view
        class="schedule-item"
        wx:for="{{todaySchedules}}"
        wx:key="_id"
        bindtap="goToSchedule"
        data-id="{{item._id}}"
      >
        <view class="schedule-time">{{item.timeDisplay}}</view>
        <view class="schedule-title">{{item.title}}</view>
        <view class="schedule-category" wx:if="{{item.category}}">{{item.category}}</view>
      </view>
    </view>

    <view class="empty-hint" wx:if="{{todaySchedules.length === 0}}">
      <text>暂无日程安排</text>
    </view>
  </view>
</view>
