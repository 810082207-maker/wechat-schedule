<!--pages/index/index.wxml-->
<view class="container">
  <!-- 日期头部 -->
  <view class="date-header">
    <text class="date-text">{{today}}</text>
  </view>

  <!-- 日程列表 -->
  <view class="schedule-list" wx:if="{{!loading}}">
    <block wx:if="{{schedules.length > 0}}">
      <view
        class="schedule-item card {{item.statusClass}}"
        wx:for="{{schedules}}"
        wx:key="_id"
        bindtap="viewScheduleDetail"
        data-id="{{item._id}}"
      >
        <view class="schedule-time">
          <text class="time-text">{{item.timeDisplay}}</text>
        </view>
        <view class="schedule-content">
          <view class="schedule-title">{{item.title}}</view>
          <view class="schedule-location" wx:if="{{item.location}}">
            <text class="iconfont">📍</text> {{item.location}}
          </view>
          <view class="schedule-tags" wx:if="{{item.tags.length > 0}}">
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
        </view>
        <view class="schedule-actions">
          <button
            class="btn-complete"
            wx:if="{{item.status === 'pending'}}"
            catchtap="completeSchedule"
            data-id="{{item._id}}"
          >完成</button>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{schedules.length === 0}}">
      <text class="empty-icon">📅</text>
      <text class="empty-text">今天还没有日程安排</text>
      <button class="btn-primary add-btn" bindtap="goToAddSchedule">添加日程</button>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab" bindtap="goToAddSchedule" wx:if="{{schedules.length > 0}}">
    <text class="fab-icon">+</text>
  </view>
</view>
